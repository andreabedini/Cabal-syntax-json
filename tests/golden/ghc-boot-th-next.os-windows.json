{"cabal-version":">=1.10","name":"ghc-boot-th-next","version":"9.11","license":"BSD3","license-file":"LICENSE","maintainer":"ghc-devs@haskell.org","bug-reports":"https://gitlab.haskell.org/ghc/ghc/issues/new","synopsis":"Shared functionality between GHC and the @template-haskell@\nlibrary","description":"This library contains various bits shared between the @ghc@ and\n@template-haskell@ libraries.\n\nThis package exists to ensure that @template-haskell@ has a\nminimal set of transitive dependencies, since it is intended to\nbe depended upon by user code.","category":"GHC","build-type":"Simple","extra-source-files":["changelog.md"],"source-repos":[{"type":"git","location":"https://gitlab.haskell.org/ghc/ghc.git","subdir":"libraries/ghc-boot-th"}],"flags":{"bootstrap":{"description":"Enabled when building the stage1 compiler in order to vendor the in-tree\n`ghc-boot-th` library, and through that the in-tree TH AST defintions from\n`ghc-internal`.\nSee Note [Bootstrapping Template Haskell]","default":false,"manual":true}},"libraries":{"ghc-boot-th-next":{"build-depends":[[{"package":"base","version":">=4.7 && <4.21","libs":["base"]},{"package":"ghc-prim","version":">=0","libs":["ghc-prim"]},{"package":"pretty","version":">=1.1 && <1.2","libs":["pretty"]}],{"_if":{"not":{"flag":"bootstrap"}},"_then":[{"package":"ghc-internal","version":">=0","libs":["ghc-internal"]}]}],"cpp-options":[{"_if":{"flag":"bootstrap"},"_then":["-DBOOTSTRAP_TH"]}],"default-extensions":[["NoImplicitPrelude"]],"default-language":["Haskell2010"],"exposed-modules":[["GHC.ForeignSrcLang.Type","GHC.Internal.TH.Lib.Map","GHC.Internal.TH.Ppr","GHC.Internal.TH.PprLib","GHC.LanguageExtensions.Type","GHC.Lexeme"],{"_if":{"flag":"bootstrap"},"_then":["GHC.Internal.TH.Lib","GHC.Internal.TH.Syntax"]}],"hs-source-dirs":[{"_if":{"flag":"bootstrap"},"_then":["../ghc-boot-th","../ghc-internal/src"]},{"_if":{"not":{"flag":"bootstrap"}},"_then":["../ghc-boot-th"]}],"other-extensions":[["DeriveGeneric"]],"other-modules":[{"_if":{"flag":"bootstrap"},"_then":["GHC.Internal.ForeignSrcLang","GHC.Internal.LanguageExtensions","GHC.Internal.Lexeme"]}],"reexported-modules":[{"_if":{"not":{"flag":"bootstrap"}},"_then":["GHC.Internal.TH.Lib","GHC.Internal.TH.Lift","GHC.Internal.TH.Quote","GHC.Internal.TH.Syntax"]}]}}}